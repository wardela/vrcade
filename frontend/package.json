{
  "name": "fawtartak",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "fawtartak financing app",
  "author": "Innovation Elements Programming Solutions",
  "scripts": {
    "start": "npm run build:frontend && electron-forge start",
    "dev": "vite",
    "build": "npm run build:frontend",
    "build:frontend": "vite build",
    "verify:dist": "node ./scripts/require-dist.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "npm run build:frontend && electron-forge package",
    "package:desktop": "npm run verify:dist && electron-forge package",
    "package:desktop:build": "npm run build:frontend && npm run package:desktop",
    "package:win": "npm run verify:dist && electron-forge package --platform=win32 --arch=x64",
    "package:win:build": "npm run build:frontend && npm run package:win",
    "electron": "electron ./electron/main.cjs",
    "make": "npm run build:frontend && electron-forge make",
    "make:desktop": "npm run verify:dist && electron-forge make",
    "make:desktop:build": "npm run build:frontend && npm run make:desktop",
    "make:win": "npm run verify:dist && electron-forge make --platform=win32 --arch=x64 --targets=@electron-forge/maker-zip",
    "make:win:build": "npm run build:frontend && npm run make:win",
    "make:win:installer": "npm run verify:dist && electron-forge make --platform=win32 --arch=x64 --targets=@electron-forge/maker-squirrel",
    "make:win:installer:build": "npm run build:frontend && npm run make:win:installer"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "daisyui": "^4.12.22",
    "dayjs": "^1.11.13",
    "dgram": "^1.0.1",
    "dotenv": "^16.4.7",
    "electron-is-dev": "^3.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.21.2",
    "i18next": "^24.2.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-datepicker": "^7.6.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.13.1",
    "react-to-print": "^2.14.13",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.1",
    "@electron-forge/maker-deb": "^7.6.1",
    "@electron-forge/maker-rpm": "^7.6.1",
    "@electron-forge/maker-squirrel": "^7.6.1",
    "@electron-forge/maker-zip": "^7.6.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.1",
    "@electron-forge/plugin-fuses": "^7.6.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^7.6.0",
    "electron": "^33.4.11",
    "electron-packager": "^17.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.5"
  },
  "config": {
    "forge": "forge.config.cjs"
  }
}
