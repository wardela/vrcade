CREATE OR REPLACE FUNCTION dev_sales.adjust_stock(\
    p_transaction_id character varying,\
    p_item_id integer,\
    p_storage_id integer,\
    p_qty numeric,\
    p_direction character varying,\
    p_type character varying,\
    p_date date,\
    p_notes text DEFAULT NULL\
)\
RETURNS void\
LANGUAGE plpgsql\
COST 100\
VOLATILE PARALLEL UNSAFE\
AS $BODY$\
BEGIN\
\
    -- Skip stock logic for non-stocked items\
    IF NOT EXISTS (\
        SELECT 1\
        FROM items\
        WHERE id = p_item_id\
          AND is_stocked = true\
    ) THEN\
        RETURN;\
    END IF;\
\
    -- Safety checks\
    IF p_qty <= 0 THEN\
        RAISE EXCEPTION 'Quantity must be greater than zero';\
    END IF;\
\
    IF p_direction NOT IN ('IN', 'OUT') THEN\
        RAISE EXCEPTION 'Invalid direction %', p_direction;\
    END IF;\
\
    IF p_date IS NULL THEN\
        RAISE EXCEPTION 'Transaction date cannot be NULL';\
    END IF;\
\
    -- Ensure storage_items row exists\
    INSERT INTO storage_items (item_id, storage_id, qty)\
    VALUES (p_item_id, p_storage_id, 0)\
    ON CONFLICT (item_id, storage_id) DO NOTHING;\
\
    -- Lock row\
    PERFORM 1\
    FROM storage_items\
    WHERE item_id = p_item_id\
      AND storage_id = p_storage_id\
    FOR UPDATE;\
\
    -- Insert transaction log with PROVIDED DATE\
    INSERT INTO transaction_logs (\
        transaction_id,\
        item_id,\
        storage_id,\
        qty,\
        direction,\
        type,\
        notes,\
        created_at\
    )\
    VALUES (\
        p_transaction_id,\
        p_item_id,\
        p_storage_id,\
        p_qty,\
        p_direction,\
        p_type,\
        p_notes,\
        p_date   -- DATE 
\f1 \uc0\u8594 
\f0  TIMESTAMP (00:00:00)\
    );\
\
    -- Update storage quantity\
    UPDATE storage_items\
    SET qty = qty + CASE\
        WHEN p_direction = 'IN' THEN p_qty\
        ELSE -p_qty\
    END\
    WHERE item_id = p_item_id\
      AND storage_id = p_storage_id;\
\
    -- Update total item quantity\
    UPDATE items\
    SET stock_qty = stock_qty + CASE\
        WHEN p_direction = 'IN' THEN p_qty\
        ELSE -p_qty\
    END\
    WHERE id = p_item_id;\
\
END;\
$BODY$;\
\
ALTER FUNCTION dev_sales.adjust_stock(\
    character varying,\
    integer,\
    integer,\
    numeric,\
    character varying,\
    character varying,\
    date,\
    text\
)\
OWNER TO postgres;\
