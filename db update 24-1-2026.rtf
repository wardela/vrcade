CREATE TABLE dev.receipt_cheques (\
    id SERIAL PRIMARY KEY,\
\
    cheque_number VARCHAR(50) NOT NULL,\
    cheque_amount NUMERIC(12,2) NOT NULL CHECK (cheque_amount > 0),\
\
    due_date DATE NOT NULL,\
    beneficiary_bank TEXT NOT NULL,\
\
    receipt_voucher_id INTEGER NOT NULL,\
\
    created_at TIMESTAMP DEFAULT NOW(),\
\
    CONSTRAINT fk_cheque_receipt\
        FOREIGN KEY (receipt_voucher_id)\
        REFERENCES dev.receipt_voucher(id)\
        ON DELETE CASCADE\
);\
