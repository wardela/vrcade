CREATE TABLE dev.receipt_voucher (\
    id SERIAL PRIMARY KEY,\
\
    due_balance_id INTEGER NOT NULL,\
    client_id INTEGER NOT NULL,\
\
    receipt_number VARCHAR(20) NOT NULL UNIQUE,\
\
    type VARCHAR(20) NOT NULL CHECK (\
        type IN ('cash', 'bank_transfer', 'cheque')\
    ),\
\
    amount NUMERIC(12,2) NOT NULL CHECK (amount > 0),\
\
    reason TEXT,\
    notes TEXT,\
\
    created_at TIMESTAMP DEFAULT NOW(),\
\
    CONSTRAINT fk_receipt_due\
        FOREIGN KEY (due_balance_id)\
        REFERENCES dev.due_balances(id)\
        ON DELETE CASCADE\
);\
\
=========\
